# Copy this file to .env and fill in your key:  cp .env.example .env

# Groq API key — get one free at https://console.groq.com/keys
# Without it the app still works, but falls back to basic rule-based coaching.
GROQ_API_KEY=gsk_your_key_here

# Any model from GET /debug/models. llama-3.1-8b-instant is faster/cheaper.
GROQ_MODEL=llama-3.3-70b-versatile

# Comma-separated origins allowed to call the API.
# In production add your deployed frontend, e.g. https://your-app.vercel.app
CORS_ORIGINS=http://localhost:5173
